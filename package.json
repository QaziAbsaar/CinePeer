{
  "name": "cinepeer",
  "version": "1.0.0",
  "description": "A cinematic desktop streaming application",
  "main": "./out/main/index.js",
  "author": "CinePeer",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev -- --disable-gpu --in-process-gpu",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "build": {
    "appId": "com.cinepeer.app",
    "productName": "CinePeer",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "public/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CinePeer",
      "license": null
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "category": "public.app-category.video"
    },
    "dmg": {
      "title": "CinePeer Installer",
      "iconSize": 128,
      "contents": [
        { "x": 140, "y": 220, "type": "file" },
        { "x": 430, "y": 220, "type": "link", "path": "/Applications" }
      ],
      "window": {
        "width": 600,
        "height": 450
      }
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Video"
    }
  },
  "dependencies": {
    "axios": "^1.7.3",
    "lucide-react": "^0.424.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "webtorrent": "^2.5.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "sharp": "^0.34.5",
    "vite": "^5.4.0"
  }
}
