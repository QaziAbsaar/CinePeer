# ── CinePeer Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your API keys.
# These are used at build time for dev convenience.
# Alternatively, enter keys via Settings page in the app.

# TMDB API Key (required — primary metadata source)
# Get one: https://www.themoviedb.org/settings/api
# VITE_TMDB_API_KEY=your_tmdb_api_key_here

# OMDb API Key (optional — fallback when TMDB unavailable)
# Get one: https://www.omdbapi.com/apikey.aspx
# VITE_OMDB_API_KEY=your_omdb_api_key_here

# Fanart.tv API Key (optional — HD image enrichment)
# Get one: https://fanart.tv/get-an-api-key/
# VITE_FANART_API_KEY=your_fanart_api_key_here

# Trakt.tv Client ID (optional — alternative discovery lists)
# Get one: https://trakt.tv/oauth/applications
# VITE_TRAKT_CLIENT_ID=your_trakt_client_id_here

# OpenSubtitles API Key (optional — subtitle downloads)
# Get one: https://opensubtitles.com/
# VITE_OPENSUBTITLES_API_KEY=your_opensubtitles_api_key_here
